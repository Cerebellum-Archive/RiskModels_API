node_modules/
.pnp
.pnp.js

# Testing
coverage/
.nyc_output
notebooks/.quickstart-executed.ipynb

# Claude Code / Cursor local tooling (machine-specific paths)
.claude/

# Local PDF snapshots from examples/scripts
risk_snapshot_*.pdf

# Snapshot pipeline build artifacts — rendered locally, never committed
sdk/riskmodels/snapshots/output/

# Tombstone for the rogue sdk/snapshots/ tree (deleted 2026-04-10).
# A stray Path resolution in tests/test_phase_a.py once created this duplicate
# of sdk/riskmodels/snapshots/. The path is fixed and the dir removed; ignore
# it so any future drift can't quietly recreate the parallel tree.
sdk/snapshots/

# Misc
*.log
*.tsbuildinfo
next-env.d.ts

# Internal maintainer docs (not for public repo)
AGENTS_INTERNAL.md

# Internal operator docs (e.g. WEBHOOKS_GUIDE.md — not committed; see internal/README.md)
internal/*
!internal/README.md

# Local audit outputs (screenshot validation, fix prompts, zero-trust QA).
# If these paths were ever committed, check git history and rotate any leaked material.
audit_findings/

# QA / marketing screenshots — may show real keys, emails, or balances if captured from a logged-in session.
site_images/

# Archived runbooks and drafts — low secret risk; optional noise for a public clone.
archive/

# Documentation build output
docs/

# OS
.DS_Store
repomix*

# Generated files
public/openapi.json

.vercel
.env*.local

# Data directories (zarr stores, local caches)
data/
*.zarr/
