# Local env and secrets — never commit
.env
.env.local
.env.*.local

# Next.js
.next/
out/
build/
dist/

# Python venvs (e.g. sdk/.venv)
.venv/
venv/

# Dependencies
node_modules/
.pnp
.pnp.js

# Testing
coverage/
.nyc_output

# Claude Code / Cursor local tooling (machine-specific paths)
.claude/

# Misc
*.log
*.tsbuildinfo
next-env.d.ts

# Internal maintainer docs (not for public repo)
AGENTS_INTERNAL.md

# Internal operator docs (e.g. WEBHOOKS_GUIDE.md — not committed; see internal/README.md)
internal/*
!internal/README.md

# Local audit outputs (screenshot validation, fix prompts, zero-trust QA).
# If these paths were ever committed, check git history and rotate any leaked material.
audit_findings/

# QA / marketing screenshots — may show real keys, emails, or balances if captured from a logged-in session.
site_images/

# Archived runbooks and drafts — low secret risk; optional noise for a public clone.
archive/

# Documentation build output
docs/

# OS
.DS_Store
repomix*

# Generated files
public/openapi.json

.vercel
.env*.local
