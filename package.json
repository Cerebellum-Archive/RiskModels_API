{
  "name": "riskmodels-api-portal",
  "version": "1.1.0",
  "private": true,
  "description": "RiskModels API Developer Portal",
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:openapi && next build",
    "vercel:sync-env": "./scripts/sync-env-to-vercel.sh",
    "vercel:sync-env:doppler": "./scripts/doppler-sync-to-vercel.sh",
    "vercel:sync-env:doppler:email": "ALLOWLIST=scripts/doppler-vercel-allowlist-email.txt ./scripts/doppler-sync-to-vercel.sh",
    "env:recon": "bash ./scripts/recon-env.sh",
    "env:recon:fingerprints": "bash ./scripts/recon-env.sh --fingerprints",
    "doppler:env": "doppler secrets download --no-file --format env -p erm3 -c dev > .env.local",
    "build:openapi": "node scripts/yaml-to-json.js",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:notebook": "python3 scripts/execute_quickstart_notebook.py",
    "cli:openapi-check": "node scripts/cli-openapi-check.mjs",
    "supabase:auth-smtp:resend": "bash ./scripts/supabase-patch-auth-smtp-resend.sh",
    "supabase:auth-smtp:resend:doppler": "bash ./scripts/supabase-auth-smtp-doppler.sh",
    "db:push": "bash ./scripts/check-supabase-cli.sh db push --linked",
    "db:migration:list": "bash ./scripts/check-supabase-cli.sh migration list --linked"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@next/mdx": "^15.1.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^1.0.4",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.2",
    "@tailwindcss/typography": "^0.5.19",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/og": "^0.11.1",
    "chalk": "^5.4.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "commander": "^13.1.0",
    "framer-motion": "^11.18.2",
    "fuse.js": "^7.1.0",
    "gray-matter": "^4.0.3",
    "inquirer": "^9.3.7",
    "js-yaml": "^4.1.0",
    "katex": "^0.16.38",
    "lucide-react": "^0.460.0",
    "next": "^15.1.0",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.0",
    "openai": "^6.33.0",
    "ora": "^8.1.1",
    "parquetjs-lite": "^0.8.7",
    "pdf-lib": "^1.17.1",
    "plaid": "^41.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "resend": "^4.1.2",
    "shiki": "^1.22.0",
    "stripe": "^20.4.1",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7",
    "zarrita": "^0.6.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^15.1.0",
    "playwright-core": "^1.59.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
