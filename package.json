{
  "name": "riskmodels-api-portal",
  "version": "1.0.1",
  "private": true,
  "description": "RiskModels API Developer Portal",
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:openapi && next build",
    "vercel:sync-env": "./scripts/sync-env-to-vercel.sh",
    "vercel:sync-env:doppler": "./scripts/doppler-sync-to-vercel.sh",
    "doppler:env": "doppler secrets download --no-file --format env > .env.local",
    "build:openapi": "node scripts/yaml-to-json.js",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@next/mdx": "^15.1.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.2",
    "@tailwindcss/typography": "^0.5.19",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "fuse.js": "^7.1.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "katex": "^0.16.38",
    "lucide-react": "^0.460.0",
    "next": "^15.1.0",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.0",
    "parquetjs-lite": "^0.8.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^1.22.0",
    "stripe": "^20.4.1",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
