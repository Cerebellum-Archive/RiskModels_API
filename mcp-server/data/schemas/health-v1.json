{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Health Status Response",
  "type": "object",
  "required": [
    "status",
    "timestamp",
    "version"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "healthy",
        "degraded",
        "down"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string"
    },
    "services": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "healthy",
              "degraded",
              "down"
            ]
          },
          "latency_ms": {
            "type": "integer"
          },
          "last_update": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "available",
              "degraded",
              "unavailable"
            ]
          },
          "avg_latency_ms_24h": {
            "type": "integer"
          },
          "success_rate_24h": {
            "type": "number"
          },
          "current_load": {
            "type": "number"
          }
        }
      }
    },
    "teo_coverage": {
      "type": "object",
      "description": "Gross-return coverage at the latest returns_gross teo in security_history; sparse values usually mean EODHD has not fully published for that session (aligned with ERM3 T coverage threshold 10%).",
      "properties": {
        "latest_teo": {
          "type": ["string", "null"],
          "format": "date",
          "description": "Latest calendar date with returns_gross rows, or null if none."
        },
        "universe_stock_count": {
          "type": "integer",
          "minimum": 0
        },
        "non_null_returns_symbol_count": {
          "type": "integer",
          "minimum": 0
        },
        "latest_teo_coverage_pct": {
          "type": ["number", "null"],
          "description": "100 * (non_null / universe) at latest_teo; null if universe is zero or count failed."
        },
        "eodhd_latest_session_pending": {
          "type": "boolean",
          "description": "True when latest_teo_coverage_pct implies ratio below 10% vs universe."
        },
        "query_error": {
          "type": "string",
          "description": "Present when Supabase queries for coverage failed."
        }
      }
    }
  }
}